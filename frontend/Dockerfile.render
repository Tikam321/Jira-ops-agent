# Frontend Dockerfile for Render
# Multi-stage build with nginx

FROM node:20-alpine AS builder

WORKDIR /app

ARG VITE_API_BASE_URL=/api
ARG VITE_FRONTEND_URL=http://localhost

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_FRONTEND_URL=$VITE_FRONTEND_URL

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM alpine:3.19 AS nginx-config

ARG BACKEND_URL=https://localhost:8081
ARG BACKEND_HOST=localhost:8081

RUN apk add --no-cache gettext

WORKDIR /build
COPY nginx.conf.template .

RUN mkdir -p /etc/nginx/conf.d && \
    envsubst '${BACKEND_URL} ${BACKEND_HOST}' < nginx.conf.template > /etc/nginx/conf.d/default.conf

FROM nginx:alpine

COPY --from=nginx-config /etc/nginx/conf.d/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
